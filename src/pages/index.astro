import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Certifications from '../components/Certifications.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="최효은 | Backend Developer Portfolio" theme="dark">
  <Nav theme="dark" />
  <main>
    <Hero variant="C" />
    <About theme="dark" />
    <Experience theme="dark" />
    <Projects theme="dark" />
    <Skills theme="dark" />
    <Certifications theme="dark" />
    <Contact theme="dark" />
  </main>
</Layout>
