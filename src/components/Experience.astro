---
const theme = Astro.props.theme || 'light';
const isDark = theme === 'dark';
const isColor = theme === 'color';

const sectionBg = isDark ? 'bg-gray-900' : isColor ? 'bg-indigo-50/50' : 'bg-surface';
const titleColor = isDark ? 'text-emerald-400' : isColor ? 'text-indigo-600' : 'text-primary';
const headingColor = isDark ? 'text-white' : 'text-text';
const borderColor = isDark ? 'border-gray-700' : 'border-border';
const hoverBorder = isDark ? 'hover:border-emerald-400' : isColor ? 'hover:border-indigo-400' : 'hover:border-primary';
const dotBorder = isDark ? 'border-gray-700 group-hover:border-emerald-400' : isColor ? 'border-border group-hover:border-indigo-400' : 'border-border group-hover:border-primary';
const dotBg = isDark ? 'bg-gray-900' : 'bg-white';
const nameColor = isDark ? 'text-white' : 'text-text';
const roleColor = isDark ? 'text-emerald-400' : isColor ? 'text-indigo-600' : 'text-primary';
const descColor = isDark ? 'text-gray-400' : 'text-text-secondary';
const tagBg = isDark ? 'bg-gray-800 text-gray-300 border-gray-700' : isColor ? 'bg-white text-gray-600 border-indigo-100' : 'bg-white text-text-secondary border-border';

const experiences = [
  {
    company: '한국에너지기술연구원 (KIER)',
    period: '2026.02 - 현재',
    role: '연구 인턴',
    project: 'AI 기반 에너지 소재 열화 예측 플랫폼 구축',
    desc: '수소연료전지 촉매의 열화 상태를 자동 예측하는 AI 분석 플랫폼을 구축했습니다. 전이학습, 데이터 증강, 클래스 가중치를 활용해 소규모, 불균형 데이터의 한계를 극복하고, 10종 딥러닝 아키텍처를 교차 검증하여 검증 정확도 99%를 달성했습니다. GradCAM, 물리 기반 커스텀 LIME, CRAFT를 적용한 XAI 프레임워크를 설계하여 모델의 판단 근거를 시각적으로 제시하고, 연구원들이 실제 연구에 활용할 수 있는 환경을 조성했습니다.',
    tags: ['Python', 'PyTorch', 'OpenCV', 'scikit-image', 'GradCAM', 'LIME', 'CRAFT'],
  },
  {
    company: 'Erste Software (Turkey)',
    period: '2024.07 - 2024.08',
    role: 'Frontend Developer',
    project: 'React 기반 웹 서비스 개발 및 데이터 처리',
    desc: '복잡하게 구조화된 설정 데이터를 사용자가 안정적으로 조회, 수정할 수 있도록 UI와 저장 로직을 구현했습니다. 작은 수정이 전체 JSON 구조에 영향을 미치는 문제를 해결하기 위해 데이터 구조와 필드 간 관계를 먼저 분석한 뒤, 변경값과 기본값을 분리 관리하는 방식으로 로직을 재설계하여 시스템 안정성을 높였습니다. 영어 기반 글로벌 환경에서 요구사항을 조율하며 협업했습니다.',
    tags: ['React', 'JavaScript', 'JSON', '영어 협업'],
  },
  {
    company: '카카오테크 캠퍼스',
    period: '2025.04 - 2025.11',
    role: 'Backend Developer',
    project: 'Spring Boot 기반 서비스 개발 및 팀 프로젝트',
    desc: '선물하기 서비스를 4단계에 걸쳐 단독 개발하며 REST API, JWT 인증, JPA, 카카오 OAuth, AWS 배포까지 백엔드 전반을 학습했습니다. 이후 6인 팀 프로젝트 UniScope에서 백엔드 3인 중 한 명으로 참여하여 기획을 주도하고, Spring Security + JWT 인증 시스템 전반을 담당했습니다.',
    tags: ['Java', 'Spring Boot', 'JPA', 'JWT', 'Spring Security', 'AWS EC2'],
  },
];
---

<section id="experience" class:list={['py-24', sectionBg]}>
  <div class="max-w-5xl mx-auto px-6">
    <h2 class:list={['text-sm font-semibold uppercase tracking-widest mb-2', titleColor]}>Experience</h2>
    <h3 class:list={['text-3xl font-bold mb-12', headingColor]}>경험</h3>
    <div class="space-y-10">
      {experiences.map((exp) => (
        <div class:list={['relative pl-8 border-l-2 transition-colors group', borderColor, hoverBorder]}>
          <div class:list={['absolute -left-[9px] top-1 w-4 h-4 rounded-full border-2 transition-colors', dotBg, dotBorder]}></div>
          <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-2">
            <div>
              <h4 class:list={['text-xl font-bold', nameColor]}>{exp.company}</h4>
              <p class:list={['font-medium text-sm', roleColor]}>{exp.role} | {exp.project}</p>
            </div>
            <span class:list={['text-sm mt-1 md:mt-0 shrink-0', descColor]}>{exp.period}</span>
          </div>
          <p class:list={['leading-relaxed mb-4', descColor]}>{exp.desc}</p>
          <div class="flex flex-wrap gap-2">
            {exp.tags.map(tag => (
              <span class:list={['px-3 py-1 text-sm rounded-full border', tagBg]}>{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
