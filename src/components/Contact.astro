---
const theme = Astro.props.theme || 'light';
const isDark = theme === 'dark';
const isColor = theme === 'color';

const titleColor = isDark ? 'text-emerald-400' : isColor ? 'text-indigo-600' : 'text-primary';
const headingColor = isDark ? 'text-white' : 'text-text';
const descColor = isDark ? 'text-gray-400' : 'text-text-secondary';
const cardStyle = isDark ? 'border-gray-800 bg-gray-900 hover:border-emerald-500/30 hover:shadow-md' : isColor ? 'border-indigo-100 bg-white hover:border-indigo-300 hover:shadow-md' : 'border-border bg-white hover:border-primary hover:shadow-md';
const iconBg = isDark ? 'bg-emerald-500/10 text-emerald-400 group-hover:bg-emerald-500 group-hover:text-gray-950' : isColor ? 'bg-indigo-50 text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white' : 'bg-primary/5 text-primary group-hover:bg-primary group-hover:text-white';
const linkColor = isDark ? 'text-gray-400 group-hover:text-white' : isColor ? 'text-gray-500 group-hover:text-gray-900' : 'text-text-secondary group-hover:text-text';
const footerBorder = isDark ? 'border-gray-800' : isColor ? 'border-indigo-100' : 'border-border';
const footerText = isDark ? 'text-gray-500' : 'text-text-secondary';
---

<section id="contact" class="py-24">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <h2 class:list={['text-sm font-semibold uppercase tracking-widest mb-2', titleColor]}>Contact</h2>
    <h3 class:list={['text-3xl font-bold mb-4', headingColor]}>연락처</h3>
    <p class:list={['mb-10', descColor]}>새로운 기회에 대해 이야기하고 싶으시다면 편하게 연락해 주세요.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="mailto:hyoeun2894@gmail.com" class:list={['flex items-center gap-3 px-6 py-4 rounded-xl border transition-all group', cardStyle]}>
        <span class:list={['w-10 h-10 flex items-center justify-center rounded-lg font-bold text-sm transition-colors', iconBg]}>@</span>
        <span class:list={['transition-colors', linkColor]}>hyoeun2894@gmail.com</span>
      </a>
      <a href="tel:010-7366-2894" class:list={['flex items-center gap-3 px-6 py-4 rounded-xl border transition-all group', cardStyle]}>
        <span class:list={['w-10 h-10 flex items-center justify-center rounded-lg font-bold text-sm transition-colors', iconBg]}>T</span>
        <span class:list={['transition-colors', linkColor]}>010-7366-2894</span>
      </a>
      <a href="https://github.com/hekengi" target="_blank" class:list={['flex items-center gap-3 px-6 py-4 rounded-xl border transition-all group', cardStyle]}>
        <span class:list={['w-10 h-10 flex items-center justify-center rounded-lg transition-colors', iconBg]}>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </span>
        <span class:list={['transition-colors', linkColor]}>github.com/hekengi</span>
      </a>
    </div>
  </div>
</section>

<footer class:list={['py-8 border-t', footerBorder]}>
  <p class:list={['text-center text-sm', footerText]}>&copy; 2026 최효은. All rights reserved.</p>
</footer>
