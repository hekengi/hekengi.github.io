---
const variant = Astro.props.variant || 'A';
---

{variant === 'A' ? (
  <!-- 디자인 A: 클린 화이트 -->
  <section class="min-h-[85vh] flex items-center pt-16">
    <div class="max-w-5xl mx-auto px-6 py-20 flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1">
        <p class="text-primary font-medium mb-4 text-lg">안녕하세요,</p>
        <h1 class="text-5xl md:text-6xl font-bold text-text leading-tight mb-6">
          최효은<span class="text-primary">.</span>
        </h1>
        <p class="text-xl md:text-2xl text-text-secondary max-w-xl leading-relaxed mb-10">
          데이터를 이해하고, 구조를 설계하고,<br />
          신뢰할 수 있는 시스템을 만드는 <strong class="text-text">백엔드 개발자</strong>입니다.
        </p>
        <div class="flex gap-4">
          <a href="https://github.com/hekengi" target="_blank"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="#contact"
            class="inline-flex items-center px-6 py-3 border-2 border-border text-text rounded-lg font-medium hover:border-primary hover:text-primary transition-colors">
            Contact
          </a>
        </div>
      </div>
      <div class="shrink-0">
        <img src="/images/profile.jpg" alt="최효은 프로필"
          class="w-64 h-80 md:w-72 md:h-[22rem] rounded-3xl object-cover object-top shadow-xl" />
      </div>
    </div>
  </section>
) : variant === 'B' ? (
  <!-- 디자인 B: 컬러 그라데이션 -->
  <section class="min-h-[85vh] flex items-center pt-16 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50">
    <div class="max-w-5xl mx-auto px-6 py-20 flex flex-col md:flex-row items-center gap-16">
      <div class="shrink-0 order-1 md:order-none">
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-3xl opacity-20 blur-lg"></div>
          <img src="/images/profile.jpg" alt="최효은 프로필"
            class="relative w-64 h-80 md:w-72 md:h-[22rem] rounded-3xl object-cover object-top shadow-xl ring-4 ring-white" />
        </div>
      </div>
      <div class="flex-1">
        <p class="text-indigo-600 font-medium mb-4 text-lg">안녕하세요,</p>
        <h1 class="text-5xl md:text-6xl font-bold text-gray-900 leading-tight mb-6">
          최효은<span class="text-indigo-500">.</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-500 max-w-xl leading-relaxed mb-10">
          데이터를 이해하고, 구조를 설계하고,<br />
          신뢰할 수 있는 시스템을 만드는 <strong class="text-gray-900">백엔드 개발자</strong>입니다.
        </p>
        <div class="flex gap-4">
          <a href="https://github.com/hekengi" target="_blank"
            class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="#contact"
            class="inline-flex items-center px-6 py-3 bg-white text-gray-700 rounded-lg font-medium hover:text-indigo-600 transition-colors shadow-md">
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <!-- 디자인 C: 다크 모드 -->
  <section class="min-h-[85vh] flex items-center pt-16 bg-gray-950">
    <div class="max-w-5xl mx-auto px-6 py-20 flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1">
        <p class="text-emerald-400 font-medium mb-4 text-lg">안녕하세요,</p>
        <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
          최효은<span class="text-emerald-400">.</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-400 max-w-xl leading-relaxed mb-10">
          데이터를 이해하고, 구조를 설계하고,<br />
          신뢰할 수 있는 시스템을 만드는 <strong class="text-white">백엔드 개발자</strong>입니다.
        </p>
        <div class="flex gap-4">
          <a href="https://github.com/hekengi" target="_blank"
            class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 text-gray-950 rounded-lg font-bold hover:bg-emerald-400 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="#contact"
            class="inline-flex items-center px-6 py-3 border-2 border-gray-700 text-gray-300 rounded-lg font-medium hover:border-emerald-400 hover:text-emerald-400 transition-colors">
            Contact
          </a>
        </div>
      </div>
      <div class="shrink-0">
        <div class="relative">
          <div class="absolute -inset-3 bg-emerald-500/20 rounded-3xl blur-xl"></div>
          <img src="/images/profile.jpg" alt="최효은 프로필"
            class="relative w-64 h-80 md:w-72 md:h-[22rem] rounded-3xl object-cover object-top shadow-2xl ring-2 ring-gray-800" />
        </div>
      </div>
    </div>
  </section>
)}
