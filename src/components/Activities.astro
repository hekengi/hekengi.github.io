---
const theme = Astro.props.theme || 'light';
const isDark = theme === 'dark';

const sectionBg = isDark ? 'bg-gray-900' : 'bg-surface';
const titleColor = isDark ? 'text-emerald-400' : 'text-primary';
const headingColor = isDark ? 'text-white' : 'text-text';
const cardBg = isDark ? 'bg-gray-950 border-gray-800 hover:border-emerald-500/30' : 'bg-white border-border hover:border-primary/30';
const roleColor = isDark ? 'text-emerald-400' : 'text-primary';
const nameColor = isDark ? 'text-white' : 'text-text';
const descColor = isDark ? 'text-gray-400' : 'text-text-secondary';
const tagStyle = isDark ? 'bg-gray-800 text-gray-300 border-gray-700' : 'bg-white text-text-secondary border-border';

const activities = [
  {
    title: '충남대 컴퓨터융합학부 학생회',
    role: '기획부장',
    desc: '학생 의견을 수렴하여 SW/AI Project Fair, CNU 창의SW/AI축전 등 학생 참여형 행사를 구상하고, 운영 설계부터 홍보, 당일 운영까지 기획 전 과정을 총괄했습니다.',
    tags: ['기획 총괄', '행사 운영', '의견 수렴'],
  },
  {
    title: '충남대 컴퓨터융합학부 서포터즈',
    role: '서포터즈',
    desc: '학과와 학생 사이의 소통 부족을 해소하기 위해 활동했습니다. 학생들의 실제 수요를 파악한 뒤, 스타트업, 연구실, 교수님을 직접 인터뷰하며 학생에게 의미 있는 기회를 발굴하고 학과 행사를 학생 눈높이에 맞게 홍보했습니다.',
    tags: ['인터뷰', '홍보', '학과-학생 연결'],
  },
];
---

<section id="activities" class:list={['py-24', sectionBg]}>
  <div class="max-w-5xl mx-auto px-6">
    <h2 class:list={['text-sm font-semibold uppercase tracking-widest mb-2', titleColor]}>Activities</h2>
    <h3 class:list={['text-3xl font-bold mb-12', headingColor]}>활동</h3>

    <div class="grid sm:grid-cols-2 gap-6">
      {activities.map(act => (
        <div class:list={['p-6 rounded-2xl border transition-all hover:shadow-lg', cardBg]}>
          <div class="mb-3">
            <span class:list={['text-sm font-semibold', roleColor]}>{act.role}</span>
            <h4 class:list={['text-lg font-bold mt-1', nameColor]}>{act.title}</h4>
          </div>
          <p class:list={['text-sm leading-relaxed mb-4', descColor]}>{act.desc}</p>
          <div class="flex flex-wrap gap-2">
            {act.tags.map(tag => (
              <span class:list={['px-3 py-1 text-sm rounded-full border', tagStyle]}>{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
