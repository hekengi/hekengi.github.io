---
import '../styles/global.css'

interface Props {
  title: string;
  project: string;
  org: string;
  period: string;
  tags: string[];
  github?: string;
  paper?: string;
}

const { title, project, org, period, tags, github, paper } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" rel="stylesheet" />
    <title>{title} | 최효은 포트폴리오</title>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased">

    <nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-md border-b border-gray-800">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-lg font-bold text-white tracking-tight">HE.</a>
        <a href="/#projects" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          프로젝트 목록
        </a>
      </div>
    </nav>

    <main class="pt-28 pb-20">
      <div class="max-w-4xl mx-auto px-6">
        <!-- Header -->
        <header class="mb-16">
          <div class="inline-block px-3 py-1 mb-4 text-sm font-medium text-emerald-400 bg-emerald-500/10 rounded-full">{org}</div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight">{project}</h1>
          <div class="flex flex-wrap items-center gap-4 mb-6">
            <span class="flex items-center gap-1.5 text-gray-400">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              {period}
            </span>
            {github && (
              <a href={github} target="_blank" class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-emerald-400 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub Repository
              </a>
            )}
            {paper && (
              <a href={paper} target="_blank" class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-emerald-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                논문 PDF
              </a>
            )}
          </div>
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="px-3 py-1 text-sm text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/20">{tag}</span>
            ))}
          </div>
        </header>

        <!-- Content -->
        <article class="prose-custom">
          <slot />
        </article>
      </div>
    </main>

    <footer class="py-8 border-t border-gray-800">
      <p class="text-center text-sm text-gray-500">&copy; 2026 최효은. All rights reserved.</p>
    </footer>

    <style is:global>
      .prose-custom h2 {
        font-size: 1.625rem;
        font-weight: 800;
        color: white;
        margin-top: 3.5rem;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #1f2937;
        letter-spacing: -0.02em;
        position: relative;
      }
      .prose-custom h2::before {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 60px;
        height: 2px;
        background: #34d399;
      }
      .prose-custom h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #e5e7eb;
        margin-top: 2.25rem;
        margin-bottom: 0.75rem;
        padding-left: 0.875rem;
        border-left: 3px solid #34d399;
        letter-spacing: -0.01em;
      }
      .prose-custom p {
        color: #9ca3af;
        line-height: 1.9;
        margin-bottom: 1.25rem;
        font-size: 0.975rem;
      }
      .prose-custom ul {
        color: #9ca3af;
        list-style-type: none;
        padding-left: 0;
        margin-bottom: 1.25rem;
      }
      .prose-custom li {
        margin-bottom: 0.625rem;
        line-height: 1.8;
        padding-left: 1.5rem;
        position: relative;
        font-size: 0.975rem;
      }
      .prose-custom li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 6px;
        height: 6px;
        background: #34d399;
        border-radius: 50%;
      }
      .prose-custom strong {
        color: #f3f4f6;
        font-weight: 600;
      }
      .prose-custom a {
        color: #34d399;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
      }
      .prose-custom a:hover {
        border-bottom-color: #34d399;
      }

      /* Diagram */
      .prose-custom .diagram {
        background: linear-gradient(135deg, #0a0a0a, #111827);
        border: 1px solid #1f2937;
        border-radius: 1rem;
        padding: 2rem;
        margin: 2rem 0;
        overflow-x: auto;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3);
      }

      /* Stats */
      .prose-custom .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin: 2rem 0;
      }
      .prose-custom .stat-card {
        background: linear-gradient(135deg, #064e3b20, #111827);
        border: 1px solid #1f2937;
        border-radius: 1rem;
        padding: 1.5rem 1rem;
        text-align: center;
        transition: border-color 0.3s, transform 0.3s;
      }
      .prose-custom .stat-card:hover {
        border-color: #34d39940;
        transform: translateY(-2px);
      }
      .prose-custom .stat-value {
        font-size: 2.25rem;
        font-weight: 800;
        color: #34d399;
        letter-spacing: -0.03em;
        line-height: 1;
      }
      .prose-custom .stat-label {
        font-size: 0.8rem;
        color: #6b7280;
        margin-top: 0.5rem;
        font-weight: 500;
        letter-spacing: 0.025em;
      }

      /* Info box */
      .prose-custom .info-box {
        background: linear-gradient(135deg, #1e1b4b30, #111827);
        border: 1px solid #312e81;
        border-radius: 1rem;
        padding: 1.5rem;
        margin: 1.5rem 0;
      }
      .prose-custom .info-box p {
        color: #c7d2fe;
        margin: 0;
      }

      /* Callout */
      .prose-custom .callout {
        background: linear-gradient(135deg, #064e3b20, #111827);
        border-left: 3px solid #34d399;
        border-radius: 0 0.75rem 0.75rem 0;
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0;
      }
      .prose-custom .callout p {
        color: #a7f3d0;
        margin: 0;
        font-style: italic;
      }
    </style>
  </body>
</html>
